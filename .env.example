# ─────────────────────────────────────────────────────────────
# BingeRoom — single root env file
# Used by: backend · web · extension
# NEVER commit .env — only .env.example goes to git
# See docs/ENV.md for where to find each value
# ─────────────────────────────────────────────────────────────

# ── APP ──────────────────────────────────────────────────────
# Your deployed URLs. In dev these are localhost.
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4001

# ── SUPABASE ─────────────────────────────────────────────────
# supabase.com → your project → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── DATABASE ─────────────────────────────────────────────────
# supabase.com → Settings → Database → Connection string
# DATABASE_URL = Transaction pooler (port 6543) — used at runtime by Prisma
# DIRECT_URL   = Direct connection  (port 5432) — used only by prisma migrate
DATABASE_URL=
DIRECT_URL=

# ── REDIS ────────────────────────────────────────────────────
# upstash.com → your database → Details → Node.js
# MUST start with rediss:// (double s = TLS). redis:// will fail silently.
REDIS_URL=

# ── DAILY.CO ─────────────────────────────────────────────────
# daily.co → Developers → API Keys
DAILY_API_KEY=
DAILY_DOMAIN=

# ── AUTH SECRETS ─────────────────────────────────────────────
# Generate BOTH with: openssl rand -hex 32
# Run it twice — two completely different values
JWT_SECRET=
INVITE_TOKEN_SECRET=

# ── PORTS ────────────────────────────────────────────────────
PORT_REST=4000
PORT_WS=4001
PORT_WEB=3000

# ── EXTENSION ────────────────────────────────────────────────
# Vite inlines these at build time into the extension bundle.
# VITE_ prefix is required for Vite to expose them.
VITE_WS_URL=ws://localhost:4001
VITE_API_URL=http://localhost:4000
VITE_APP_URL=http://localhost:3000
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── WEB APP ──────────────────────────────────────────────────
# Next.js exposes NEXT_PUBLIC_ prefixed vars to the browser.
NEXT_PUBLIC_WS_URL=ws://localhost:4001
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
